# Supabase設定（アカウント同期を使う場合に必要）
# https://supabase.com/ でプロジェクトを作成して値を取得
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GOOGLE_WEB_CLIENT_ID=your-google-web-application-client-id.apps.googleusercontent.com
VITE_GOOGLE_NATIVE_CLIENT_ID=your-google-desktop-client-id.apps.googleusercontent.com
VITE_GOOGLE_NATIVE_CLIENT_SECRET=
